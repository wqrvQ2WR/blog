---
import type { ImageMetadata } from 'astro';
import BlogPost from '../layouts/BlogPost.astro';
import { getLivePosts, renderPostHtml } from '../lib/posts';

// 배포 빌드에서는 모든 글을 정적 페이지로 생성한다.
// 개발 서버에서는 astro.config.mjs 의 dev-live-posts 훅이 이 라우트를
// 요청 시 렌더링으로 전환해, /create 로 만든 글이 즉시 보인다.
export async function getStaticPaths() {
	const allPosts = await getLivePosts();
	return allPosts.map((p) => ({ params: { num: String(p.num) } }));
}

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/*.{jpg,jpeg,png,webp}', {
	eager: true,
});
function resolveHero(heroImage?: string) {
	if (!heroImage) return undefined;
	if (heroImage.startsWith('/')) return heroImage; // public/ 폴더 이미지 (업로드된 이미지)
	const name = heroImage.split('/').pop();
	return Object.entries(images).find(([key]) => key.endsWith(`/${name}`))?.[1].default;
}

const num = Number(Astro.params.num);
const posts = await getLivePosts();
const post = Number.isInteger(num) && num >= 1 ? posts[num - 1] : undefined;

if (!post) {
	return new Response('글을 찾을 수 없습니다.', { status: 404 });
}

const prev = posts[num - 2];
const next = posts[num];
---

<BlogPost
	title={post.title}
	description={post.description}
	pubDate={post.pubDate}
	updatedDate={post.updatedDate}
	heroImage={resolveHero(post.heroImage)}
>
	<div set:html={renderPostHtml(post)} />

	<nav class="post-nav">
		{
			prev ? (
				<a class="prev" href={`/${prev.num}`}>
					<span class="label">← 이전 글</span>
					<span class="post-title">{prev.title}</span>
				</a>
			) : (
				<span class="prev empty" />
			)
		}
		<a class="up" href="/blog">목록으로</a>
		{
			next ? (
				<a class="next" href={`/${next.num}`}>
					<span class="label">다음 글 →</span>
					<span class="post-title">{next.title}</span>
				</a>
			) : (
				<span class="next empty" />
			)
		}
	</nav>
</BlogPost>

<style>
	.post-nav {
		display: flex;
		align-items: stretch;
		gap: 1em;
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.post-nav a {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
		padding: 0.8em 1em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		text-decoration: none;
		transition: 0.2s ease;
	}
	.post-nav a:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.prev,
	.next {
		flex: 1;
		min-width: 0;
	}
	.next {
		text-align: right;
		align-items: flex-end;
	}
	.empty {
		border: none;
	}
	.label {
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	.post-title {
		font-weight: bold;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 100%;
	}
	.up {
		align-self: center;
		justify-content: center;
		font-weight: bold;
		white-space: nowrap;
	}
	@media (max-width: 720px) {
		.post-nav {
			flex-direction: column;
		}
		.next {
			text-align: left;
			align-items: flex-start;
		}
		.up {
			order: 3;
			align-self: stretch;
			text-align: center;
		}
		.empty {
			display: none;
		}
	}
</style>
