---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getLivePosts } from '../../lib/posts';

const images = import.meta.glob<{ default: ImageMetadata }>('../../assets/*.{jpg,jpeg,png,webp}', {
	eager: true,
});
function resolveHero(heroImage?: string) {
	if (!heroImage) return undefined;
	if (heroImage.startsWith('/')) return heroImage; // public/ 폴더 이미지 (업로드된 이미지)
	const name = heroImage.split('/').pop();
	return Object.entries(images).find(([key]) => key.endsWith(`/${name}`))?.[1].default;
}

// 작성 순서대로 번호가 붙어 있고, 목록은 최신 글부터 보여준다.
const posts = (await getLivePosts()).reverse();
const categories = [...new Set(posts.map((p) => p.category).filter(Boolean))];
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.search {
				margin-bottom: 2rem;
			}
			.search input {
				width: 100%;
				padding: 0.6em 1em;
				font-size: 1em;
				font-family: inherit;
				color: rgb(var(--black));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				box-sizing: border-box;
			}
			.search input:focus {
				outline: none;
				border-color: var(--accent);
			}
			.categories {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-bottom: 2rem;
			}
			.categories button {
				font: inherit;
				font-size: 0.9em;
				padding: 0.3em 1em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				background: white;
				color: rgb(var(--gray-dark));
				cursor: pointer;
			}
			.categories button:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.categories button.active {
				background: var(--accent);
				border-color: var(--accent);
				color: white;
			}
			.category-tag {
				display: inline-block;
				margin-left: 0.6em;
				padding: 0.1em 0.7em;
				font-size: 0.8em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				color: rgb(var(--gray));
			}
			.no-results {
				margin: 2rem 0;
				text-align: center;
				color: rgb(var(--gray));
			}
			/* 검색 중에는 첫 글 크게 보여주는 레이아웃을 풀어 균일하게 표시 */
			ul.searching li:first-child {
				width: calc(50% - 1rem);
				margin-bottom: 0;
				text-align: inherit;
			}
			ul.searching li:first-child .title {
				font-size: inherit;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
				ul.searching li:first-child {
					width: 100%;
					text-align: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="search">
					<input
						type="search"
						id="search-input"
						placeholder="글 검색 (제목)"
						autocomplete="off"
					/>
				</div>
				{
					categories.length > 0 && (
						<div class="categories" id="category-filter">
							<button type="button" class="active" data-category="">
								전체
							</button>
							{categories.map((c) => (
								<button type="button" data-category={c}>
									{c}
								</button>
							))}
						</div>
					)
				}
				<ul id="post-list">
					{
						posts.map((post) => {
							const hero = resolveHero(post.heroImage);
							return (
								<li data-num={post.num} data-category={post.category ?? ''}>
									<a href={`/${post.num}`}>
										{
											typeof hero === 'string' ? (
												<img width="720" src={hero} alt="" />
											) : (
												hero && <Image width={720} height={360} src={hero} alt="" />
											)
										}
										<h4 class="title">#{post.num} {post.title}</h4>
										<p class="date">
											<FormattedDate date={post.pubDate} />
											{post.category && <span class="category-tag">{post.category}</span>}
										</p>
									</a>
								</li>
							);
						})
					}
				</ul>
				<p class="no-results" id="no-results" hidden>검색 결과가 없습니다.</p>
			</section>
		</main>
		<Footer />
		<script>
			const input = document.getElementById('search-input') as HTMLInputElement;
			const list = document.getElementById('post-list')!;
			const noResults = document.getElementById('no-results')!;
			const items = [...list.querySelectorAll<HTMLLIElement>('li[data-num]')];
			const titles = items.map((li) => li.querySelector('.title')!.textContent!.toLowerCase());
			const filterBar = document.getElementById('category-filter');

			let activeCategory = '';

			function applyFilters() {
				const query = input.value.trim().toLowerCase();
				if (!query && !activeCategory) {
					list.classList.remove('searching');
					items.forEach((li) => (li.hidden = false));
					noResults.hidden = true;
					return;
				}
				list.classList.add('searching');
				let count = 0;
				items.forEach((li, i) => {
					const show =
						(!query || titles[i].includes(query)) &&
						(!activeCategory || li.dataset.category === activeCategory);
					li.hidden = !show;
					if (show) count++;
				});
				noResults.hidden = count > 0;
			}

			input.addEventListener('input', applyFilters);

			filterBar?.addEventListener('click', (e) => {
				const button = (e.target as HTMLElement).closest('button');
				if (!button) return;
				activeCategory = button.dataset.category ?? '';
				filterBar.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === button));
				applyFilters();
			});
		</script>
	</body>
</html>
